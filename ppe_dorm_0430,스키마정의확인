<select id="selectList" resultType="resultData">
	    <!-- 첫 번째 SELECT (일반 학생) -->
	    SELECT
	        DOMASTER.DONG,
	        DOMASTER.SIL,
	        DOMASTER.SIL2,
	        SHJHAKJM.HAKGWA,
	        DOMASTER.HAKYEON,
	        DOMASTER.HAKBUN,
	        SHJHAKJM.IRUM,
	        DOMASTER.DORMGBN,
	        DECODE(DOMASTER.SEX, '1', '남', '2', '여') AS SEX,
	        DOMASTER.IPGBN,
	        EAGLE.SF_GET_DEPT(SHJHAKJM.DAEHAK) AS DAEHAKFNM,
	        SGCHAKCM.HAKGWAFNM AS HAKGWAFNM,
	        EAGLE.SF_GET_DEPT(SHJHAKJM.JUNGONG) AS JUNGONGFNM,
	        SHJADDRM.HSPOSTJUSO ||' '||SHJADDRM.HSJUSO AS HSPOSTJUSO,
	        SHJADDRM.HSJUSO,
	        DOMASTER.STATE,
	        SGCCODEM.CDFNM AS HJSTATE,
	        SUBSTR(SHJHAKJM.JUMINNO, 1, 6) AS JUMINNO,
	        DOMASTER.BJUMSU,
	        DOMASTER.RCJUMSU,
	        DOMASTER.BANKACC,
	        DORMPAYT.NAPIPGUM,
	        DECODE(DOMASTER.NAPIPGBN, '1', '완납', '2', '분납') AS NAPIPGBN,
	        NATIONAL.CDFNM AS NATIONAL,
	        DECODE(DOMASTER.WEEKENDAMT, '1', '신청', '2', '미신청') AS WEEKENDAMT,
	        DOMASTER.BANKNAME,
	        DOMASTER.BANKNUM,
	        DOMASTER.ACCNAME,
	        CASE WHEN DOMASTER.STATE IN ('11','21','31','41') THEN '1인실'
	             WHEN DOMASTER.STATE IN ('12','22','32','42') THEN '2인실'
	             ELSE '' END AS INSIL,
	        DORMCSD.CONTENTS AS CVSVCT,
	        DORMGLH.APND_FILE_ID AS APND_FILE_ID,
	        REPLACE(REPLACE(SHJADDRM.HSTEL, '-', ''), ' ', '') AS HSTEL,
	        REPLACE(REPLACE(SHJADDRM.HSBBTEL, '-', ''), ' ', '') AS HSBBTEL,
	        DOMASTER.SEQ,
	        CASE WHEN DORMPAYT.SCHLDATE IS NOT NULL THEN SUBSTR(DORMPAYT.SCHLDATE, 1, 4)||'-'||SUBSTR(DORMPAYT.SCHLDATE, 5, 2)||'-'||SUBSTR(DORMPAYT.SCHLDATE, 7, 2) END AS SCHLDATE
	    FROM
	        EAGLE.DOMASTER DOMASTER
	    JOIN EAGLE.SHJHAKJM SHJHAKJM ON DOMASTER.HAKBUN = SHJHAKJM.HAKBUN
	    LEFT JOIN EAGLE.SHJADDRM SHJADDRM ON DOMASTER.HAKBUN = SHJADDRM.HAKBUN
	    JOIN EAGLE.SGCHAKCM SGCHAKCM ON SHJHAKJM.HAKGWA = SGCHAKCM.HAKGWA
	    LEFT JOIN (SELECT * FROM EAGLE.SGCCODEM WHERE SUBSTR(CODE,1,2) = '05') SGCCODEM ON SHJHAKJM.HJSTATE = SGCCODEM.CODE
	    LEFT JOIN (SELECT * FROM EAGLE.SGCCODEM WHERE CODE LIKE 'A6%') DONG ON DOMASTER.DONG = DONG.CDFNM
	    LEFT JOIN (SELECT SCHLYEAR, SCHLSMST, STNTNUMB, MAX(SCHLDATE) AS SCHLDATE, (MAX(NVL(AMNT0001,0))+MAX(NVL(AMNT0002,0))+ MAX(NVL(AMNT0003,0))+MAX(NVL(AMNT0004,0))) as NAPIPGUM FROM EAGLE.DORMPAYT GROUP BY SCHLYEAR, SCHLSMST, STNTNUMB) DORMPAYT
	        ON DOMASTER.HAKBUN = DORMPAYT.STNTNUMB AND DOMASTER.YEONDO = DORMPAYT.SCHLYEAR AND DOMASTER.HAKGI = DORMPAYT.SCHLSMST
	    LEFT JOIN EAGLE.DORMCSD DORMCSD
	        ON DOMASTER.HAKBUN = DORMCSD.HAKBUN AND DOMASTER.YEONDO = DORMCSD.YEAR AND DOMASTER.HAKGI = DORMCSD.HAKGI
	    LEFT JOIN EAGLE.DORMGLH DORMGLH
	        ON DOMASTER.HAKBUN = DORMGLH.HAKBUN AND DOMASTER.YEONDO = DORMGLH.YEAR
	    LEFT JOIN (SELECT HAKBUN, IRUM, NATIONAL, CDFNM FROM EAGLE.SHJHAKJM JOIN EAGLE.SGCCODEM ON SHJHAKJM.NATIONAL = SGCCODEM.CODE) NATIONAL
	        ON DOMASTER.HAKBUN = NATIONAL.HAKBUN
	    WHERE
	        DOMASTER.STATE Between '1' And '6'
	        AND DOMASTER.YEONDO = #{yeondo}
	        AND DOMASTER.HAKGI = #{hakgi}
	        AND (SHJHAKJM.HAKBUN NOT LIKE 'L%' OR SHJHAKJM.HAKBUN NOT IN (SELECT HAKBUN FROM EAGLE.KOLP_MST))
	
	    <!-- 동적 검색 조건 (WHERE 절의 마지막 부분에 AND를 직접 붙여줘야 함) -->
	    <if test="search != null and search != ''">
	        AND (DOMASTER.HAKBUN LIKE #{search} || '%' OR SHJHAKJM.IRUM LIKE #{search} || '%')
	    </if>
	    <if test="nation != null and nation != ''">
	        AND NATIONAL.NATIONAL = #{nation}
	    </if>
	    <if test="dong != null and dong != ''">
	        AND (DOMASTER.DONG = #{dong} OR #{dong} = '- 전 체 -')
	    </if>
	
	    <choose>
	        <when test="insil != null and insil == '1'">
	            AND ( (DOMASTER.STATE IN ('11','21','31','41')
	                   OR (DOMASTER.STATE IN ('12','22','32','42') AND DOMASTER.SINGLE = 'Y') )
	                )
	        </when>
	        <when test="insil != null and insil == '2'">
	            AND DOMASTER.STATE IN ('12','22','32','42')
	        </when>
	    </choose>
	
	    UNION ALL
	
	    <!-- 두 번째 SELECT (국제 교류 학생) -->
	    SELECT
	        DOMASTER.DONG AS DONG,
	        DOMASTER.SIL AS SIL,
	        DOMASTER.SIL2 AS SIL2,
	        '1A07' AS HAKGWA,
	        DOMASTER.HAKYEON,
	        DOMASTER.HAKBUN AS HAKBUN,
	        KOLP_MST.KNM AS IRUM,
	        DOMASTER.DORMGBN AS DORMGBN,
	        DECODE(DOMASTER.SEX, '1', '남', '2', '여') AS SEX,
	        DOMASTER.IPGBN,
	        '' AS DAEHAKFNM,
	        '국제교류교육원' AS HAKGWAFNM,
	        '' AS JUNGONGFNM,
	        KOLP_MST.HANGPOSTJUSO AS HSPOSTJUSO,
	        '' AS HSJUSO,
	        DOMASTER.STATE,
	        DECODE(KOLP_MST.ST_STATUS,'0501','재학','') AS HJSTATE,
	        SUBSTR(KOLP_JUPSU_APLY.BIRTH, 3, 8) AS JUMINNO,
	        DOMASTER.BJUMSU,
	        DOMASTER.RCJUMSU,
	        DOMASTER.BANKACC,
	        DORMPAYT.NAPIPGUM,
	        DECODE(DOMASTER.NAPIPGBN, '1', '완납', '2', '분납') AS NAPIPGBN,
	        NATIONAL.CDFNM AS NATIONAL,
	        DECODE(DOMASTER.WEEKENDAMT, '1', '신청', '') AS WEEKENDAMT,
	        DOMASTER.BANKNAME,
	        DOMASTER.BANKNUM,
	        DOMASTER.ACCNAME,
	        CASE WHEN DOMASTER.STATE IN ('11','21','31','41') THEN '1인실'
	             WHEN DOMASTER.STATE IN ('12','22','32','42') THEN '2인실'
	             ELSE '' END AS INSIL,
	        DORMCSD.CONTENTS AS CVSVCT,
	        DORMGLH.APND_FILE_ID AS APND_FILE_ID,
	        KOLP_JUPSU_APLY.DMS_TEL AS HSTEL,
	        KOLP_MST.MV_PHONE AS HSBBTEL,
	        DOMASTER.SEQ,
	        CASE WHEN DORMPAYT.SCHLDATE IS NOT NULL THEN SUBSTR(DORMPAYT.SCHLDATE, 1, 4)||'-'||SUBSTR(DORMPAYT.SCHLDATE, 5, 2)||'-'||SUBSTR(DORMPAYT.SCHLDATE, 7, 2) END AS SCHLDATE
	    FROM
	        EAGLE.DOMASTER DOMASTER
	    JOIN EAGLE.KOLP_MST KOLP_MST ON KOLP_MST.HAKBUN = DOMASTER.HAKBUN
	    JOIN EAGLE.KOLP_JUPSU_APLY KOLP_JUPSU_APLY
	        ON KOLP_MST.SUHUMNO = KOLP_JUPSU_APLY.SUHUMNO
	        AND KOLP_MST.YEAR = KOLP_JUPSU_APLY.YEAR
	        AND KOLP_MST.HAKGI = KOLP_JUPSU_APLY.HAKGI
	    LEFT JOIN (SELECT * FROM EAGLE.SGCCODEM WHERE CODE LIKE 'A6%') DONG ON DOMASTER.DONG = DONG.CDFNM
	    LEFT JOIN (SELECT SCHLYEAR, SCHLSMST, STNTNUMB, MAX(SCHLDATE) AS SCHLDATE, (MAX(NVL(AMNT0001,0))+MAX(NVL(AMNT0002,0))+ MAX(NVL(AMNT0003,0))+MAX(NVL(AMNT0004,0))) as NAPIPGUM FROM EAGLE.DORMPAYT GROUP BY SCHLYEAR, SCHLSMST, STNTNUMB) DORMPAYT
	        ON DOMASTER.HAKBUN = DORMPAYT.STNTNUMB AND DOMASTER.YEONDO = DORMPAYT.SCHLYEAR AND DOMASTER.HAKGI = DORMPAYT.SCHLSMST
	    LEFT JOIN EAGLE.DORMCSD DORMCSD
	        ON DOMASTER.HAKBUN = DORMCSD.HAKBUN AND DOMASTER.YEONDO = DORMCSD.YEAR AND DOMASTER.HAKGI = DORMCSD.HAKGI
	    LEFT JOIN EAGLE.DORMGLH DORMGLH
	        ON DOMASTER.HAKBUN = DORMGLH.HAKBUN AND DOMASTER.YEONDO = DORMGLH.YEAR
	    LEFT JOIN (SELECT HAKBUN, IRUM, NATIONAL, CDFNM FROM EAGLE.SHJHAKJM JOIN EAGLE.SGCCODEM ON SHJHAKJM.NATIONAL = SGCCODEM.CODE) NATIONAL
	        ON DOMASTER.HAKBUN = NATIONAL.HAKBUN
	    WHERE
	        DOMASTER.STATE Between '1' And '6'
	        AND DOMASTER.YEONDO = #{yeondo}
	        AND DOMASTER.HAKGI = #{hakgi}
	
	    <!-- 동적 검색 조건 -->
	    <if test="search != null and search != ''">
	        AND (DOMASTER.HAKBUN LIKE #{search} || '%' OR KOLP_MST.KNM LIKE #{search} || '%')
	    </if>
	    <if test="nation != null and nation != ''">
	        AND NATIONAL.NATIONAL = #{nation}
	    </if>
	    <if test="dong != null and dong != ''">
	        AND (DOMASTER.DONG = #{dong} OR #{dong} = '- 전 체 -')
	    </if>
	
	    <choose>
	        <when test="insil != null and insil == '1'">
	            AND ( (DOMASTER.STATE IN ('11','21','31','41')
	                   OR (DOMASTER.STATE IN ('12','22','32','42') AND DOMASTER.SINGLE = 'Y') )
	                )
	        </when>
	        <when test="insil != null and insil == '2'">
	            AND DOMASTER.STATE IN ('12','22','32','42')
	        </when>
	    </choose>
	
	    ORDER BY DONG, SIL, SIL2
	</select>

    -- 에러 내용 
    -- ORA-00904: "SF_GET_DEPT" 부적합한 식별자 
    -- 위의 내용은 앞에 EAGLE라는 스키마를 명시하지 않아서, SF-GET_DEPT라는 컬럼을 찾지 못해서 발생했음 

    -- 원인 ::  SF_GET_DEPT의 앞에 EAGLE.을 붙이지 않았기에 발생했음

-- SF_GET_DEPT라는 함수가 어느 스키마에 정의 되어있는지 확인 
-- OWNER의 칼럼에 나오는 값이 SF_GET_DEPT가 속한 스키마인 것을 확인할 수 있다.     
SELECT OWNER, OBJECT_NAME, OBJECT_TYPE
FROM ALL_OBJECTS
WHERE OBJECT_NAME = 'SF_GET_DEPT';