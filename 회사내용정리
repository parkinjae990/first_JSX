	<update id="saveCopy" statementType="CALLABLE">
	{ CALL
		BEGIN
			
	    DELETE FROM TB_ADEV_CORE_ABILITY -- 핵심역량정의
			 WHERE YEAR				= #{toYear};
			
		DELETE FROM TB_ADEV_LWPRT_ABILITY -- 하위역량정의
			 WHERE YEAR				= #{toYear};
		
		DELETE FROM TB_ADEV_CORE_ABILITY_GHVR_IDX -- 행동지표
			 WHERE YEAR				= #{toYear}; 
		<!-- 핵심역량정의-->	 
		INSERT INTO TB_ADEV_CORE_ABILITY (
				    YEAR                      -- 년도
				  , CORE_ABILITY_CD           -- 핵심역량코드
				  , CORE_ABILITY_NM           -- 핵심역량명
				  , CORE_ABILITY_NM_ENG       -- 핵심역량명_영문
				  , CORE_ABILITY_ABRV         -- 핵심역량약어
				  , CLTR_FRMTN_DFN            -- 핵심역량정의
				  , SORT_ORDR				  -- 정렬순서
	              , INP_ID          		  -- 생성자
	              , INP_DT            		  -- 생성일시
	              , INP_IP            		  -- 생성IP
	              , INP_PRGM          		  -- 생성프로그램
				)
			  SELECT 
			        #{toYear}
				  , CORE_ABILITY_CD     
				  , CORE_ABILITY_NM     
				  , CORE_ABILITY_NM_ENG 
				  , CORE_ABILITY_ABRV   
				  , CLTR_FRMTN_DFN      
				  , SORT_ORDR			
			      , #{_userSession_.loginId}
			      , SYSDATE
			      , #{_userSession_.connectIp}
			      , #{_program_.prgmUrl}
			   FROM TB_ADEV_CORE_ABILITY
			  WHERE YEAR			= #{fromYear};
			  
		
		<!-- 하위역량정의-->
		INSERT INTO TB_ADEV_LWPRT_ABILITY (
				    YEAR  				  -- 년도
				  , CORE_ABILITY_CD  	  -- 핵심역량코드
				  , LWPRT_ABILITY_CD  	  -- 핵심역량명
				  , LWPRT_ABILITY_NM  	  -- 핵심역량명_영문
				  , LWPRT_ABILITY_NM_ENG  -- 핵심역량약어
				  , LWPRT_ABILITY_ABRV    -- 핵심역량정의
				  , LWPRT_ABILITY_DFN     -- 정렬순서
				  ,	ALLOT				  -- 배점
				  , SORT_ORDR             -- 정렬순서
				  , USE_AT                -- 사용여부
	              , INP_ID          	  -- 생성자
	              , INP_DT            	  -- 생성일시
	              , INP_IP            	  -- 생성IP
	              , INP_PRGM          	  -- 생성프로그램
				)
			  SELECT 
			        #{toYear}
				  , CORE_ABILITY_CD  	 
				  , LWPRT_ABILITY_CD  	 
				  , LWPRT_ABILITY_NM  	 
				  , LWPRT_ABILITY_NM_ENG 
				  , LWPRT_ABILITY_ABRV   
				  , LWPRT_ABILITY_DFN    
				  , ALLOT				 
				  , SORT_ORDR           
				  , USE_AT                	
			      , #{_userSession_.loginId}
			      , SYSDATE
			      , #{_userSession_.connectIp}
			      , #{_program_.prgmUrl}
			   FROM TB_ADEV_LWPRT_ABILITY
			  WHERE YEAR			= #{fromYear};	 
			  
			   
		
		INSERT INTO TB_ADEV_CORE_ABILITY_GHVR_IDX (
				    YEAR 				-- 년도
				  , CORE_ABILITY_CD 	-- 핵심역량코드
				  , LWPRT_ABILITY_CD 	-- 하위역량코드
				  , SN 					-- 순번문
				  , COMPOSITION_FACTOR 	-- 구성요소
				  , GHVR_IX_CASE 		-- 행동지표
				  , SORT_ORDR 			-- 정렬순서
	              , INP_ID          	-- 생성자
	              , INP_DT            	-- 생성일시
	              , INP_IP            	-- 생성IP
	              , INP_PRGM          	-- 생성프로그램
				)
			  SELECT 
			        #{toYear}
				  , CORE_ABILITY_CD 	
				  , LWPRT_ABILITY_CD 	
				  , SN 					
				  , COMPOSITION_FACTOR 
				  , GHVR_IX_CASE 		
				  , SORT_ORDR 			
			      , #{_userSession_.loginId}
			      , SYSDATE
			      , #{_userSession_.connectIp}
			      , #{_program_.prgmUrl}
			   FROM TB_ADEV_CORE_ABILITY_GHVR_IDX
			  WHERE YEAR			= #{fromYear};	 	
