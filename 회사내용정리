#// HAK_SPTP_1015_M00 업체참여신청,  undefined로 나오는 값 N으로 변경 후 ,해결하는 방법
=================================================================================
# 기존에 발생했던 문제점 
1.	조회 후 행 클릭했을 때, fv_comptAt가 체크 되어있지 않는 경우, undefined로 설정 되어있음
2.	학기 컴포넌트의 값 변경시, 그리드의 데이터가 조회가되나, 체크박스의 값이 N이 아닌 undefined
3.	 fv_comptAt값을 Y로 바꾼 뒤 저장하면, 기존의 undefined 값을 가지는 다른 행의 컴포넌트들도 readonly가 걸려있음 
4.	체크 후 , 저장하고, 다시 체크를 해제하기 위해 ,기존에 체크를 통해  tab_main.Tabpage1.form.div_main.form.chk_comptAt을 'Y'로 변경하면, 이후 다시 수정할 수 없음


// 1. 행 변경 시 (조회 직후 또는 그리드 클릭 시)
this.ds_list_onrowposchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
    // B. 현재 행의 신청여부 값 가져오기
    var fv_comptAt = obj.getColumn(obj.rowposition, "comptAt");
    
    // C. 값 보정 (NULL, undefined, 빈값 -> "N"으로 변환) - [문제 1, 2 해결]
    if (GFN.isNull(fv_comptAt)) {
        fv_comptAt = "N";
    }

    // D. 화면 컴포넌트 제어 함수 호출 
    this.fn_setComponentStatus(fv_comptAt);

    // E. 탭 조회
    if(this.tab_main.tabindex == 1){
        this.tab_main.tabpages[this.tab_main.tabindex].form.fn_search();
    }
};

// 2. 컬럼 값 변경 시 (체크박스 클릭 즉시 반응)
this.ds_list_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
    // 신청여부(comptAt) 컬럼이 변경되었을 때만 동작
    if (e.columnid == "comptAt") {
        
        var sVal = e.newvalue;
        if (GFN.isNull(sVal)){
		sVal = "N";
		} 
        
        // 화면 컴포넌트 제어 함수 호출
        this.fn_setComponentStatus(sVal);
