this.fn_saveCheck = function () {
	//마감여부 체크 시 마감일시 검사

	var validationMappings = {
		"xcomp" : this.ds_list, //DataSet
		"bulcode" : { //코드번호
			"required" : {
				colNm : "코드번호"
			}
		},
		"buljum" : { //차량명
			"required" : {
				colNm : "벌점"
			}
		},
		"bulnm" : { //사용가능 좌석수
			"required" : {
				colNm : "상,벌점 명칭 "
			}
		},
	};
	return this.gfn_validation(this, validationMappings);
};

/**
* 저장 처리 
* @return
*/
