create or replace NONEDITIONABLE FUNCTION         UF_ENTS_REGT_STTUS
(
   P_GUBUN   VARCHAR2  /*1:둥록구분  2:등록일자*/
	,P_YEAR    VARCHAR2  /*입시년도*/
	,P_EXMT_NO VARCHAR2   /*수헙번호*/
	
)
RETURN VARCHAR2

IS
    V_RESULT       	VARCHAR2(100);
    V_REGT_SE_CD    VARCHAR2(10);
    V_FPY_AT        VARCHAR2(1);

BEGIN
V_RESULT:= '';

IF  P_GUBUN = '1'  THEN
		SELECT REGT_SE_CD
		INTO  V_RESULT
		FROM  CNTUEDU.VA_TI_REGT_TRGTER

		WHERE YEAR = P_YEAR
		AND EXMT_NO = P_EXMT_NO
	
		;
ELSE
     IF   P_GUBUN = '2'  THEN
			  	SELECT PAY_DE
					INTO  V_RESULT
					FROM  CNTUEDU.VA_TI_REGT_TRGTER

					WHERE YEAR = P_YEAR
					AND EXMT_NO = P_EXMT_NO
				
					;

     END IF;

END IF;


 RETURN (V_RESULT);

END;


