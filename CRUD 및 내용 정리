/* dataPass가 존재하는 팝업의 경우 
1) 상급자한테 만든다고 말하기 
2) Nexacro의 Application의 PopupSelectList.js에 팝업 이름 및 양식에 맞게 작성함 
예시 : PPE_DORM_0030_M00.xfdl
*/

// 돋보기 버튼 클릭시 팝업 
this.div_search_btn_searchUser_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var v_hakbun = this.div_search.form.edt_hakbun.value; // 학번 입력 필드의 값
 
	var options = {
		callback : "fn_callbackPop",                    // 후처리 
		value : v_hakbun,                               // 팝업 파라미터로 전달되는 값 
		userNm : this.div_search.form.edt_hakbun.value, // 해당 팝업의 쿼리를 추적하여, 쿼리에 필요한 파라미터를 생성
		dataPass : true,                                // 팝업을 생성하기 전 dataPass가 실행되어, 조회 결과가 1개의 행을 반환할 경우, 팝업 화면을 보여주지 않음 
	};
	this.gfn_popup("CMM_PPUP_USER_P03", options);	    // 보여줄 팝업명
	//break;
};

// 학생조회 팝업 콜백 (후처리:: 팝업이 종료된 후 실행되는 내용 )
this.fn_callbackPop = function(svcid, data)
{
	this.ds_in.setColumn(0, "hakbun",data.empno);			//학번
	this.ds_in.setColumn(0, "irum"  ,data.userNm);			//성명
	this.div_search.form.edt_hakgwa.set_value(data.deptNm);	//직번
	this.fn_search();

};


// 사진 조회 스크립트 
this.fn_searchPhoto = function() {
	this.ds_photo.clearData();
	
	var conifg = {	
		nameSpace : "PpeDorm0380Mapper",
		sqlId	  : "selectPhoto",
		outds	  : "ds_photo",
		params 	  : {
			hakbun : this.ds_list.getColumn(0, "hakbun")
		}
	};	
	this.gfn_searchBlob(conifg, function() {
		var photo = this.ds_photo.getColumn(0, "photo");
		if (!Eco.isEmpty(photo)) {
			this.img_Pic.set_stretch("fit");
			this.img_Pic.set_image(this.ds_photo.getColumn(0, "photo"));
		} else {
			this.gfn_resetImageViewer(this.img_Pic);
		}		
	});
};

