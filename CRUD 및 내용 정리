this.fn_insert = function(){
	// 그리드에 바인딩 되어있는 데이터셋의 행을 추가 
	var	nRow	=	this.ds_list.addRow(); // 행 추가 
    this.ds_list.setColumn(0, "irum", this.edt_irum.value)  // 0번째 행의 이름 칼럼에 이름 컴포넌트의 값을 추가함
    this.ds_list.setColumn(0,"addr",this.edt_addr.value)    // 0번째 행의 주소 칼럼에 주소 컴포넌트의 값을 추가함
    this.ds_list.setColumn(0,"hbtel",this.edt_hbtel.value)  // 0번째 행의 핸드폰 컬럼에 핸드폰 컴포넌트의 값을 추가함

} 


/*
* 저장 유효성 검사
**rowState가 1이면 저장 유효성 검사를 할 수 없음 
*/
this.fn_saveCheck = function () {
	//마감여부 체크 시 마감일시 검사

	var validationMappings = {
		"xcomp" : this.ds_list, //DataSet
		"bulcode" : { //코드번호
			"required" : {
				colNm : "코드번호"
			}
		},
		"buljum" : { //차량명
			"required" : {
				colNm : "벌점"
			}
		},
		"bulnm" : { //사용가능 좌석수
			"required" : {
				colNm : "상,벌점 명칭 "
			}
		},
	};
	return this.gfn_validation(this, validationMappings);
};

/**
* 저장 처리 
* @return
*/
this.fn_save = function () {
	
	if (!this.fn_saveCheck()) {
 		return;
 	}
// grid를 선택할 수 있지만 rowCount를 가져오지 못하기에, ds_list를 생성
	this.gfn_saveRow(this.ds_list, function (oData) { 
		oData.sController = ComService.$.CONTROLLER;
		oData.svcList = [
			{
				action	  : ComService.$.SAVE,
				nameSpace : "PpeDorm0370Mapper",
				sqlId	  : ["insert", "update", ""],       //mapper에서 존재하는 id가 insert와 update인 쿼리를 실행하겠다는 의미 
				inds	  : "ds_list:U",
// 				validSql  : { //저장시 키 중복조회가 필요한 경우 (return null or return 0)
// 					nameSpace : "AdmGood0030Mapper",
// 					sqlId	  : "selectDupCheck",
// 					value	  : "0", //유효한 값, 해당 값 외 리턴시에는 false
// 					msg		  : this.gfn_getMsg("중복된 데이터가 존재합니다.")
// 				}
			}
		];	
		ComService.doAction(this, oData).then(function(form, e) {
			form.gfn_setStatus("save");
			form.fn_search();
		});	
	});
};
/**
* 삭제 처리
* @return
*/
this.fn_delete = function()
{
	this.gfn_deleteRow(this.ds_list, function (oData){ // grid를 선택할 수 있지만 rowCount를 가져오지 못하기에, ds_list를 생성
		oData.sController = ComService.$.CONTROLLER;	
		oData.svcList = [
				{
					action	  : ComService.$.DELETE,
					nameSpace : "PpeDorm0370Mapper",
					sqlId	  : "delete",
					inds	  : "ds_list:U",
				}
		];
			
		ComService.doAction(this, oData).then(function(form, e) {
			form.gfn_alertMsg("삭제완료");
			form.fn_search();
		});
	});
};


