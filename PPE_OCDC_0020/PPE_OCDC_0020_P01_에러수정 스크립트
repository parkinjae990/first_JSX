// 날짜 차이 계산 
this.fn_getDiffDay = function(sStartDate, sEndDate)
{
    // 입력값 유효성 검사 (길이가 8이 아니거나, 비어있을 경우)
    if (GFN.isNull(sStartDate) || GFN.isNull(sEndDate) || sStartDate.length != 8 || sEndDate.length != 8)
    {
        return ; // Not a Number 반환
    }

    // YYYY, MM, DD로 분리하여 Date 객체 생성
    // JavaScript에서 월(Month)은 0부터 시작하므로 -1을 적용 
    var dStartDate = new Date(sStartDate.substring(0, 4), sStartDate.substring(4, 6) - 1, sStartDate.substring(6, 8));
    var dEndDate   = new Date(sEndDate.substring(0, 4), sEndDate.substring(4, 6) - 1, sEndDate.substring(6, 8));

    // getTime()으로 밀리초 단위 시간차를 구함
    var nTimeDiff = dEndDate.getTime() - dStartDate.getTime();

    // 밀리초를 일수(Day)로 변환 (1000ms * 60s * 60m * 24h)
    var nDayDiff = Math.ceil(nTimeDiff / (1000 * 60 * 60 * 24));

    return nDayDiff;
}

// 인원 수에 따른 방 개수 로직 
this.fn_inwonPerRoom = function()
{
	var maxPeoplePerRoom = 7;  // 객실 1개당 최대 인원
	var maxRooms = 8;          // roomType별 최대 예약 가능 객실 수
	
	// 데이터셋에서 현재 값 가져오기 
	var inwonTotal = this.ds_in.getColumn(0, "inwonTotal"); // 현재 입력된 총 인원
	var currentRoomCnt = this.ds_in.getColumn(0, "roomCount"); // 현재 설정된 객실 수
	
	// 현재 설정된 객실 수로 수용 가능한 최대 인원을 계산
	var maxCapacity = currentRoomCnt * maxPeoplePerRoom;
	
	// maxRooms보다 더 큰 값일 경우 
	if(maxRooms < currentRoomCnt){
		this.gfn_alertMsg("각 타입별 최대 예약 가능 객실 수는 8개 입니다.")
		return false;
	}
	// 입력된 총 인원이 현재 객실의 수용 가능 인원을 초과하는지 확인
	if (inwonTotal > maxCapacity) {
		// 변수 설정 :: 총 인원에 필요한 객실 수를 계산(올림 처리). 
		var requiredRooms = Math.ceil(inwonTotal / maxPeoplePerRoom);
		
		// 필요한 객실 수가 최대 예약 가능 객실 수(8개)를 초과하는지 확인
		if (requiredRooms > maxRooms) {
			// 최대 수용 인원을 초과했다는 알림을 표시
			var maxTotalCapacity = maxRooms * maxPeoplePerRoom;
			this.gfn_alertMsg("총 인원이 최대 이용 가능 인원(" + maxTotalCapacity + "명)을 초과했습니다.");
			
			// 인원수를 최대 수용 가능 인원으로, 객실 수를 최대 객실 수로 재설정
			this.spn_inwon.set_value(maxTotalCapacity);
			this.ds_in.setColumn(0, "inwonTotal", maxTotalCapacity);
			this.ds_in.setColumn(0, "roomCount", maxRooms); // 객실 수도 최대로 설정
			return false;
		}
		// 객실을 추가하면 예약이 가능한 경우.
		else {
			// 사용자에게 필요한 객실 수를 알려줌.
			this.gfn_alertMsg(inwonTotal + "명이 이용하려면 최소 " + requiredRooms + "개의 객실이 필요합니다. 객실 수를 조정해주십시오.");
		
			return false;
		}
	}
	return true;
}

// 시작 일자 
this.cal_startdt_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var staDate = this.cal_startdt.value;
	var endDate = this.cal_enddt.value;
	
	
	
	if(staDate < GFN.getToday())
	{	
		this.gfn_alertMsg('시작일자를 바르게 선택하십시오.');
		this.cal_startdt.set_value(GFN.getToday());
		this.ds_in.setColumn(0,"staDate",this.cal_startdt.value);
		this.fn_setDs_in();
		this.fn_search();
		
		return;
	}

	if(staDate >= endDate)
	{	
		this.cal_enddt.set_value(this.fn_getNextDay(staDate) ); // 입력한 staDate보다 하루더 많은 값을 데이터로 담아야함 
		this.ds_in.setColumn(0,"endDate",this.cal_enddt.value);	
		this.fn_setDs_in();
		this.fn_search();
		return;
		
	}else{
		// 종료일자가 시작일자보다 클 때
		this.cal_startdt.set_value(staDate)
		this.ds_in.setColumn(0,"staDate",staDate);			
		this.fn_search();
	}
		

	this.ds_in.setColumn(0,"staDate",this.cal_startdt.value);
	this.ds_in.setColumn(0,"endDate",this.cal_enddt.value);
	this.fn_setDs_in();
};

// 종료 일자 
