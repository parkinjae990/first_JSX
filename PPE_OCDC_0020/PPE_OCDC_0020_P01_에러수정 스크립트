// 지정한 날짜의 다음 날 가져오기 
this.fn_getNextDay = function(sBaseDate)
{
    // 입력값 유효성 검사
    if (GFN.isNull(sBaseDate) || sBaseDate.length != 8)
    {
        return ""; 
    }

    // 1. 기준 날짜 문자열을 기반으로 Date 객체를 생성
    var year = parseInt(sBaseDate.substr(0, 4));
    var month = parseInt(sBaseDate.substr(4, 2)) - 1; // 월은 0부터 시작
    var day = parseInt(sBaseDate.substr(6, 2));
    var objDate = new Date(year, month, day);

    // 2. 생성된 Date 객체에 하루를 추가
    objDate.setDate(objDate.getDate() + 1);

    // 3. 다음 날짜를 "YYYYMMDD" 형식의 문자열로 변환
    var nextYear = objDate.getFullYear();
    var nextMonth = (objDate.getMonth() + 1).toString().padLeft(2, "0");
    var nextDay = objDate.getDate().toString().padLeft(2, "0");
    
    return nextYear + nextMonth + nextDay;
}

