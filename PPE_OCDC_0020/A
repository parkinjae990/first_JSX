   SELECT 'N' AS FLAG
        , SHJHAKJM.HAKBUN
        , SHJHAKJM.IRUM
        , SGCHAKCM.HAKGWAFNM
        , SHJHAKJM.HAKYOUN
        , DECODE(SHJHAKJM.SEX, '1', '남', '2', '여') AS SEX
        , SGCCODEM_HJSTATE.CDFNM AS HJSTATE -- 별칭 변경
        , SHJADDRM.HSBBTEL
        , SHJADDRM.HSTEL
        , SHJADDRM.HSPOSTJUSO ||' '|| SHJADDRM.HSJUSO AS HSPOSTJUSO
        , CASE WHEN DOMASTER.HAKBUN IS NOT NULL THEN '0' -- DOMASTER가 조인되지 않으면 NULL이므로 IS NOT NULL 사용
                 ELSE '1' END AS GUBUN
        , DOMASTER.DORMGBN         
        , DOMASTER.STATE 
        , DOMASTER.DONG       
        , DOMASTER.SIL
        , DOMASTER.SIL2       
        , DOMASTER.IPGBN        
        , DOMASTER.NAPIPGBN
        , DOMASTER.SINGLE  --1인실
        , DOMASTER.USEONCHK    
        , TO_CHAR(DOMASTER.TOESADATE, 'YYYYMMDD') AS TOESADATE
        , DOMASTER.SEQ
        , 'N' AS CHK   
        , NVL(DOMASTER.YEONDO,#{yeondo}) AS YEONDO
        , NVL(DOMASTER.HAKGI,#{hakgi}) AS HAKGI
        , SGCCODEM_NATIONAL.CDFNM AS NATIONAL -- 별칭 변경
        , DOMASTER.WEEKENDAMT --주말식비
FROM EAGLE.SHJHAKJM SHJHAKJM
INNER JOIN EAGLE.SGCHAKCM SGCHAKCM
        ON SHJHAKJM.HAKGWA = SGCHAKCM.HAKGWA
INNER JOIN EAGLE.SHJADDRM SHJADDRM
        ON SHJHAKJM.HAKBUN = SHJADDRM.HAKBUN   
INNER JOIN (SELECT CODE, CDFNM FROM EAGLE.SGCCODEM WHERE SUBSTR(CODE,1,2) = '05') SGCCODEM_HJSTATE -- HJSTATE용 SGCCODEM
        ON SHJHAKJM.HJSTATE = SGCCODEM_HJSTATE.CODE 
INNER JOIN EAGLE.SGCCODEM SGCCODEM_NATIONAL -- NATIONAL용 SGCCODEM
        ON SHJHAKJM.NATIONAL = SGCCODEM_NATIONAL.CODE
LEFT JOIN EAGLE.DOMASTER DOMASTER
        ON SHJHAKJM.HAKBUN = DOMASTER.HAKBUN 
        AND DOMASTER.YEONDO = #{yeondo}
        AND DOMASTER.HAKGI  = #{hakgi}