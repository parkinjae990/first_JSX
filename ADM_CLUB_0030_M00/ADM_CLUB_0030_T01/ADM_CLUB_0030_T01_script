//엑셀업로드
this.btn_importExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sSheet = "head=Sheet1!A1:ZZZ1;body=Sheet1!A2;";
	this.gfn_importExcelByMappings(this, this.ds_excel, [
		"maeipdate", "goods", "danga", "qty", "danwi", "amt", "bigo", "clubcode", "userid"
	], true, sSheet, function () {
				
		for(var i = 0; i < this.ds_excel.rowcount; i++){		
			var vMaeipdate  = this.ds_excel.getColumn(i, "maeipdate");
			var vGoods = this.ds_excel.getColumn(i, "goods");
			var vDanga = this.ds_excel.getColumn(i, "danga");
			var vQty  = this.ds_excel.getColumn(i, "qty");		
			var vDanwi  = this.ds_excel.getColumn(i, "danwi");
			var vAmt  = this.ds_excel.getColumn(i, "amt");
			var vBigo  = this.ds_excel.getColumn(i, "bigo");
			var vClubcode  = this.ds_excel.getColumn(i, "clubcode");
			var vUserid  = this.ds_excel.getColumn(i, "userid");
						
			this.ds_list.set_enableevent(false);
			var nRow = this.ds_list.addRow();
			
			this.ds_list.setColumn(nRow, "maeipdate", vMaeipdate);
			this.ds_list.setColumn(nRow, "goods", vGoods);
			this.ds_list.setColumn(nRow, "danga", vDanga);			
			this.ds_list.setColumn(nRow, "qty", vQty);			
			this.ds_list.setColumn(nRow, "danwi", vDanwi);				
			this.ds_list.setColumn(nRow, "amt", vAmt);			
			this.ds_list.setColumn(nRow, "bigo", vBigo);			
			this.ds_list.setColumn(nRow, "clubcode", vClubcode);
			this.ds_list.setColumn(nRow, "userid", vUserid);
			this.ds_list.setColumn(nRow, "excelGbn", "Y");	//엑셀업로드 구분
			
			this.ds_list.set_enableevent(true);
		}
		
		this.gfn_alertMsg("작업이 정상적으로 완료되었습니다.");
	});
};


